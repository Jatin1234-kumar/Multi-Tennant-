NODE_ENV=development
PORT=4000
DATABASE_URL=
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL=15m
BCRYPT_ROUNDS=10
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
TENANT_CACHE_TTL_MS=60000
PLATFORM_PROVISIONING_KEY=replace-with-platform-provisioning-key
ALLOW_TENANT_HEADER=true
DEMO_TENANT_NAME=Acme Labs
DEMO_TENANT_SUBDOMAIN=acme
DEMO_ADMIN_EMAIL=admin@acme.com
DEMO_ADMIN_PASSWORD=Password@123
