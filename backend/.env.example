NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/multitenant_saas
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=10000
JWT_ACCESS_SECRET=replace-with-strong-secret
JWT_ACCESS_TTL=15m
BCRYPT_ROUNDS=12
CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
PLATFORM_PROVISIONING_KEY=replace-with-platform-provisioning-key
